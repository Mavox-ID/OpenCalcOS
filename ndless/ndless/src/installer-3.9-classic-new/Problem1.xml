                local bit_shiftLeft = function(int, n)
                    return int*2^n
                end

                local bit_shiftRight = function(int, n)
                    return math.floor(int/2^n)
                end

                local bit_and = function(a, b)
                    local result = 0
                    local d = 256
                    while d &gt;= 1 do
                        d = d/2
                        local aa,bb = a-d, b-d
                        local aaa,bbb = aa&gt;=0, bb&gt;=0
                        if aaa and bbb then result = result + d end
                        if aaa then a = aa end
                        if bbb then b = bb end
                    end
                    return result
                end

                function nibble_to_color(n)
                    return n*0x10+0xF
                end

                function byte2colors(byte)
                    local c1 = nibble_to_color(bit_shiftRight(byte, 4))
                    local c2 = nibble_to_color(bit_and(byte, 0xF))

                    return c1, c1, c1, c2, c2, c2
                end

                function drawByteString(gc, x, y, byteString)
                    local width = 320

                    for i=0, #byteString-1 do
                        local r1,g1,b1, r2,g2,b2 = byte2colors(byteString:byte(i+1))

                        local xx = (x + i*2) % width
                        local yy = y + math.floor((x + i*2) / width)

                        gc:setColorRGB(r1, g1, b1)
                        gc:fillRect(xx, yy, 1, 1)
                        gc:setColorRGB(r2, g2, b2)
                        gc:fillRect(xx+1, yy, 1, 1)
                    end
                end

